# Sentinel-Dispatch — variables de entorno
# Copiar a .env y rellenar. Nunca commitear .env real.

# === App ===
APP_ENV=local           # local | demo
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-me-in-real-deploy

# === Persistencia ===
DATABASE_URL=sqlite+aiosqlite:///./data/sentinel.db

# === OSM Graph ===
GRAPH_PATH=./data/graphs/coquimbo.graphml
GRAPH_PLACE="La Serena, Coquimbo, Chile"
GRAPH_BBOX_NORTH=-29.5
GRAPH_BBOX_SOUTH=-30.5
GRAPH_BBOX_EAST=-70.5
GRAPH_BBOX_WEST=-71.7

# === Logging ===
LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json         # json | console (console solo para desarrollo)

# === Métricas ===
METRICS_ENABLED=true
METRICS_PATH=/metrics
