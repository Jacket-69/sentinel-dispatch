# =============================================================================
# Data (estado runtime y artefactos pesados)
# =============================================================================

# Eventos JSONL (ADR-0007 — estado runtime, no se versiona)
data/eventos.jsonl
data/eventos*.jsonl

# Outputs de comparación dual (regenerables)
/tmp/python-out/
/tmp/java-out/

# OSM cached graphs (grandes; se generan con core-python/scripts/build_graph.py)
data/graphs/*.graphml
data/graphs/*.pkl
data/graphs/*.osm
!data/graphs/.gitkeep
# Excepción: el grafo Coquimbo se commitea como fixture reproducible para IT-01
# (ADR-0010 §3). Regenerable vía `make build-graph`.
!data/graphs/coquimbo.graphml

# OSRM oracle data (generado por tools/build_osrm_oracle.sh — ~600 MB de PBF +
# sidecars). El único artefacto committeado es tests/fixtures/osrm_oracle.json.
data/osrm/*
!data/osrm/.gitkeep

# Cache de Overpass de OSMnx (generado al descargar grafos)
cache/

# Logs
*.log
logs/

# Reportes generados (regenerables vía CI)
docs/quality/rt-validation-report.md

# =============================================================================
# Backups locales
# =============================================================================
backups/

# =============================================================================
# Contratos para agentes IA — privados, no se versionan
# =============================================================================
CLAUDE.md
AGENTS.md
